# Alle Textdateien: LF im Repository, OS-native Zeilenenden beim Checkout
* text=auto eol=lf

# Kotlin / Java / XML / Gradle: explizit LF
*.kt        text eol=lf
*.java      text eol=lf
*.xml       text eol=lf
*.kts       text eol=lf
*.toml      text eol=lf
*.properties text eol=lf
*.md        text eol=lf
*.pro       text eol=lf

# Shell-Skript: muss LF behalten (sonst bricht gradlew)
gradlew     text eol=lf

# Windows-Batch: CRLF
gradlew.bat text eol=crlf

# Binärdateien: kein Zeilenenden-Handling
*.jar       binary
*.webp      binary
*.png       binary
*.jpg       binary
*.keystore  binary
*.jks       binary
