    <string name="info_privacy_auth_label">Authentication</string>
    <string name="info_privacy_auth_value">You sign in with your Bosch account. Your session stays on this device and is not stored by this app on an extra server.</string>
    <string name="info_privacy_storage_label">Local storage</string>
    <string name="info_privacy_storage_value">Your rides, bike data and export files are stored locally on your device so the app can open them faster and create exports offline.</string>
    <string name="info_privacy_backup_label">Backup policy</string>
    <string name="info_privacy_backup_value">Automatic Android backup is turned off for this app, so sensitive ride data and sign-in information are not copied into system backups.</string>
    <string name="info_privacy_sync_label">Network transfers</string>
    <string name="info_privacy_sync_value">The app only contacts Bosch when you sign in or refresh your data. Background sync runs only if you switch it on in Setup.</string>
    <string name="info_legal_status_label">Status</string>
    <string name="info_legal_status_value">This is an independent companion app. It is not operated or officially supported by Bosch eBike Systems.</string>
    <string name="info_legal_support_label">Support</string>
    <string name="info_legal_support_value">Questions, bugs and feature requests are handled through the project repository, not through Bosch support.</string>
    <string name="info_legal_data_act_label">Data access basis</string>
    <string name="info_legal_data_act_value">The app uses the Bosch account access provided for Smart System data so it can show the rides and bike information available to you.</string>
    <string name="info_credit_bosch">Bosch eBike Systems provides the Smart System and the ride and bike data that can be shown in this app.</string>
    <string name="info_credit_data_act">The EU Data Act is part of the legal framework that makes this kind of data access possible.</string>
    <string name="info_credit_codex">OpenAI Codex helped with parts of the software development for this project.</string>
