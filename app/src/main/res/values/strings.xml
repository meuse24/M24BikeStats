    <string name="setup_title">Setup</string>
    <string name="setup_subtitle">This is where app settings live that directly affect export and usage.</string>
    <string name="setup_csv_title">CSV format</string>
    <string name="setup_csv_subtitle">Choose whether CSV exports use the automatic device-based format or a fixed export preset.</string>
    <string name="setup_sync_title">Cloud sync details</string>
    <string name="setup_sync_subtitle">Choose whether cloud sync loads only missing activity details or also refreshes stale cached details.</string>
    <string name="setup_background_sync_title">Background sync</string>
    <string name="setup_background_sync_subtitle">Choose whether the app schedules a daily Smart System sync in the background and which network conditions it should require.</string>
    <string name="setup_csv_example">Example: %1$s</string>
    <string name="setup_csv_sample_activity">Morning ride</string>
    <string name="csv_export_format_system_default_label">Automatic</string>
    <string name="csv_export_format_system_default_description">Uses the device decimal conventions to choose a fitting CSV preset, for example semicolon plus decimal comma on German systems.</string>
    <string name="csv_export_format_excel_de_label">Excel/German</string>
    <string name="csv_export_format_excel_de_description">Semicolon as separator with decimal comma and consistent quoting.</string>
    <string name="csv_export_format_standard_international_label">Standard/International</string>
    <string name="csv_export_format_standard_international_description">Comma as separator with decimal point and consistent quoting.</string>
    <string name="cloud_sync_detail_mode_missing_only_label">Missing only</string>
    <string name="cloud_sync_detail_mode_missing_only_description">Loads activity details only when none are cached yet. Lowest data usage.</string>
    <string name="cloud_sync_detail_mode_missing_or_stale_label">Missing + stale</string>
    <string name="cloud_sync_detail_mode_missing_or_stale_description">Loads missing details and refreshes cached details once they become stale.</string>
    <string name="background_sync_mode_disabled_label">Disabled</string>
    <string name="background_sync_mode_disabled_description">No periodic background sync is scheduled.</string>
    <string name="background_sync_mode_daily_unmetered_label">Daily on Wi-Fi</string>
    <string name="background_sync_mode_daily_unmetered_description">Schedules one background sync about every 24 hours and requires an unmetered network.</string>
    <string name="background_sync_mode_daily_connected_label">Daily on any network</string>
    <string name="background_sync_mode_daily_connected_description">Schedules one background sync about every 24 hours on any connected network.</string>

    <string name="help_title">Help</string>
    <string name="help_subtitle">Quick overview of navigation, data flow and diagnostics.</string>
    <string name="help_login_label">Login</string>
    <string name="help_login_text">Sign in with your Bosch account. After that, the app opens the main areas and can load your bikes and rides.</string>
    <string name="help_activities_label">Activities</string>
    <string name="help_activities_text">Here you can browse all saved rides, search in them and sort the list. “All tours on map” opens a world map with one point per ride. Tap a point to jump straight to that ride. If you go back, the map opens again where you left it.</string>
    <string name="help_bike_label">Account</string>
    <string name="help_bike_text">The account area shows your connected Bosch Smart System bikes together with basic account information. The app works with the current Bosch Smart System and does not support eBike System 2 or eBike Connect.</string>
    <string name="help_setup_label">Setup</string>
    <string name="help_setup_text">In Setup you choose the CSV format, how much detail cloud sync reloads, and whether background sync runs daily on Wi-Fi, on any network, or stays off.</string>
    <string name="help_functions_label">Functions</string>
    <string name="help_functions_text">In Functions you can export your saved data as CSV or as a PDF report. The exports use the data already available on your device and then open the normal Android share menu. The CSV format follows your setting from Setup, while the PDF uses your current app language and regional format.</string>
    <string name="help_statistics_label">Statistics</string>
    <string name="help_statistics_text">The statistics screen groups your rides by week, month or year. You can quickly compare distance, ride time and number of rides, and you can tap a period to see the details below the chart. The highlights section also shows personal bests, your strongest period, your average riding speed and your usual riding rhythm.</string>
    <string name="help_diagnostics_label">Diagnostics</string>
    <string name="help_diagnostics_text">The API test screen is meant for troubleshooting and development. That is why it is not part of the normal main navigation.</string>

