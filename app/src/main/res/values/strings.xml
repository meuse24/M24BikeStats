    <string name="info_copyright_value">(c) 2026 meuse24, Author: Guenther Meusburger</string>
    <string name="info_privacy_auth_label">Authentication</string>
    <string name="info_privacy_auth_value">Sign-in uses Bosch SingleKey ID through AppAuth. The app stores the resulting session only locally on the device.</string>
    <string name="info_privacy_storage_label">Local storage</string>
    <string name="info_privacy_storage_value">Ride, bike and export data are cached in the local Room database. Tokens are kept in encrypted shared preferences.</string>
    <string name="info_privacy_backup_label">Backup policy</string>
    <string name="info_privacy_backup_value">Android auto backup and device-transfer backup are disabled so cached Bosch data and tokens are not copied into cloud backups by the OS.</string>
    <string name="info_privacy_sync_label">Network transfers</string>
    <string name="info_privacy_sync_value">The app talks to Bosch endpoints only for login and Smart System data sync. Background sync runs only when explicitly enabled in Setup.</string>
    <string name="info_legal_status_label">Status</string>
    <string name="info_legal_status_value">This is an unofficial companion app and is not operated, endorsed or supported by Bosch eBike Systems.</string>
    <string name="info_legal_support_label">Support</string>
    <string name="info_legal_support_value">Support and issue handling happen through the project repository and not through Bosch support channels.</string>
    <string name="info_legal_data_act_label">Data access basis</string>
    <string name="info_legal_data_act_value">The app relies on Bosch account access and the Bosch eBike Data Act portal to access the rider data shown here.</string>
    <string name="info_credit_bosch">Bosch eBike Systems provides the Smart System, the related cloud interfaces and thus the technical foundation for the ride and bike data shown in this app.</string>
    <string name="info_credit_data_act">The EU Data Act, Regulation (EU) 2023/2854, defines harmonised rules for fair access to and fair use of product and service data and therefore forms the regulatory framework for data access of this kind.</string>
    <string name="info_credit_codex">Codex by OpenAI is an agentic software engineering assistant that can read codebases, make changes, run tests and execute tasks in isolated environments.</string>
    <string name="info_credit_claude_code">Claude Code by Anthropic is an agentic coding system for terminal, IDE and web that can plan across projects, edit files, run tests and use development tools directly.</string>
    <string name="info_credit_gemini_cli">Gemini CLI by Google is an open source AI agent for the terminal that brings Gemini into the command line for coding, research, automation and problem solving.</string>
    <string name="info_credit_openfreemap">OpenFreeMap by Zsolt Ero provides the map tiles and styles used in the app; the rendered map stack builds on OpenMapTiles and OpenStreetMap data.</string>

